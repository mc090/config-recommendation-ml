# GitHub API Configuration
GITHUB_TOKEN=your_github_token_here  # Personal Access Token for GitHub API

# Repository Search Criteria
MIN_STARS=10  # Minimum GitHub stars for repository inclusion
MAX_REPOS=1000  # Maximum number of repositories to collect (it is maximum, not target - actual may be lower due to filtering)
EXCLUDE_FORKS=True  # Exclude forked repositories
EXCLUDE_ARCHIVED=True  # Exclude archived repositories  
MAX_TIME_SINCE_UPDATE_DAYS=365  # Maximum days since last repository update (0 = no limit)
MIN_SIZE_KB=10  # Minimum repository size (in KB)
MAX_SIZE_KB=500000  # Maximum repository size (in KB)

# API Rate Limiting
REQUESTS_PER_MINUTE=60  # Max REST API requests per minute (for Trees API, tarball downloads, etc. GitHub Search API has a hard limit of 30 req/min regardless of this setting)
MIN_REQUEST_DELAY=1  # Minimum delay between requests in seconds (to prevent bursts that trigger secondary rate limits)

# Reproducibility
RANDOM_SEED=90  # Random seed for shuffling and sampling
STRATIFY_LABELS=["has_pyproject_toml","has_dockerfile","has_github_actions"]  # Dataset stratification labels (Labels to use for multi-label stratification in train/test splits)

# Dataset Versioning
DATASET_VERSION=1.0.0  # Manual version override (optional)

# Output Paths (optional - defaults will be used if not set)
RAW_DATA_PATH=data/raw/raw_metadata.json
STRUCTURE_PATH=data/interim/structure.json
STRUCTURE_ENRICHED_PATH=data/interim/structure_enriched.json
COMPUTED_FEATURES_PATH=data/interim/computed_features.json
DATASET_OUTPUT_DIR=data/processed
LOGS_DIR=logs
